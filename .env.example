# Database
# Docker-ready: use service name "yellow-hood-postgres" when running in Docker.
# For local dev against a local Postgres, use "localhost" instead of "yellow-hood-postgres".
DATABASE_URL="postgresql://postgres:postgres@yellow-hood-postgres:5432/yellow_hood_db?schema=public"

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
